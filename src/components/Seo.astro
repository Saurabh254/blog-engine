---
import { SITE, absoluteUrl, pageTitle } from '../lib/site';
import { resolvePublicSrc } from '../lib/images';

interface Props {
  title: string;
  description?: string;
  canonicalPath: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  canonicalPath,
  type = 'website',
  publishedAt,
  image,
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://blog.saurabhvishwakarma.in');
const fullTitle = pageTitle(title);
const canonical = absoluteUrl(canonicalPath, site);
const ogImagePath = image ? resolvePublicSrc(image) : undefined;
const ogImage = ogImagePath ? absoluteUrl(ogImagePath, site) : absoluteUrl('/favicon.svg', site);

const jsonLd =
  type === 'article' && publishedAt
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: publishedAt.toISOString(),
        dateModified: publishedAt.toISOString(),
        author: {
          '@type': 'Person',
          name: SITE.author,
          url: SITE.authorUrl,
        },
        publisher: {
          '@type': 'Person',
          name: SITE.author,
          url: SITE.authorUrl,
        },
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
        url: canonical,
        image: [ogImage],
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: `${SITE.name} · ${SITE.author}`,
        description: SITE.description,
        url: absoluteUrl('/', site),
        author: {
          '@type': 'Person',
          name: SITE.author,
          url: SITE.authorUrl,
        },
      };
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:site_name" content={`${SITE.name} · ${SITE.author}`} />
{type === 'article' && publishedAt && (
  <meta property="article:published_time" content={publishedAt.toISOString()} />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={SITE.twitter} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
