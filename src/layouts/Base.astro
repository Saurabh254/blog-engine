---
import '../styles/global.css';

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-dvh bg-[#e8ecf8] font-sans text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100"
  >
    <div
      class="pointer-events-none fixed inset-0 bg-[radial-gradient(ellipse_90%_60%_at_8%_-8%,rgba(99,102,241,0.18),transparent_55%),radial-gradient(ellipse_70%_50%_at_95%_12%,rgba(139,92,246,0.12),transparent_50%)] dark:opacity-40"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto w-full max-w-xl px-5 py-10 sm:px-6 sm:py-14">
      <header class="mb-10 flex items-baseline justify-between gap-4 border-b border-zinc-900/10 pb-4 dark:border-zinc-100/10">
        <a
          href="/"
          class="text-base font-semibold tracking-tight text-zinc-900 hover:text-indigo-600 dark:text-zinc-100 dark:hover:text-indigo-400"
        >
          my blog
        </a>
        <a
          href="https://saurabhvishwakarma.in"
          class="text-xs text-zinc-500 transition-colors hover:text-indigo-600 dark:text-zinc-400 dark:hover:text-indigo-400"
        >
          portfolio →
        </a>
      </header>

      <main>
        <slot />
      </main>

      <footer class="mt-16 border-t border-zinc-900/10 pt-6 text-xs text-zinc-500 dark:border-zinc-100/10 dark:text-zinc-400">
        <p>write markdown, ship posts.</p>
      </footer>
    </div>
  </body>
</html>
