---
import Base from './Base.astro';

const { title, description, date } = Astro.props;
const formatted = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Base title={title} description={description}>
  <article>
    <a
      href="/"
      class="mb-8 inline-block text-sm text-zinc-500 transition-colors hover:text-indigo-600 dark:text-zinc-400 dark:hover:text-indigo-400"
    >
      ← all posts
    </a>

    <header class="mb-8 border-b border-zinc-900/10 pb-6 dark:border-zinc-100/10">
      <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-[1.75rem]">
        {title}
      </h1>
      <time class="mt-2 block text-sm text-zinc-500 dark:text-zinc-400" datetime={date}>
        {formatted}
      </time>
    </header>

    <div
      class="prose prose-zinc max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-h2:border-b prose-h2:border-zinc-900/10 prose-h2:pb-2 prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-img:border prose-img:border-zinc-900/10 dark:prose-img:border-zinc-100/10 prose-code:rounded prose-code:bg-zinc-900/5 prose-code:px-1 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none prose-pre:rounded-lg prose-pre:border prose-pre:border-zinc-900/10 prose-blockquote:border-indigo-500 prose-blockquote:text-zinc-600 dark:prose-invert dark:prose-headings:text-zinc-50 dark:prose-h2:border-zinc-100/10 dark:prose-a:text-indigo-400 dark:prose-code:bg-zinc-100/10 dark:prose-pre:border-zinc-100/10 dark:prose-blockquote:text-zinc-400"
    >
      <slot />
    </div>
  </article>
</Base>
