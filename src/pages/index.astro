---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---
<Base title="blog">
  {posts.length === 0 ? (
    <p class="text-muted">No posts yet.</p>
  ) : (
    <ol class="list-none space-y-2 p-0">
      {posts.map((post, index) => (
        <li class="flex flex-wrap items-baseline gap-x-1.5 leading-snug">
          <span class="w-5 shrink-0 text-right text-muted tabular-nums">{index + 1}.</span>
          <span>
            <a
              href={`/${post.id}`}
              class="text-ink no-underline visited:text-ink hover:underline"
            >
              {post.data.title}
            </a>
            <span class="text-muted"> ({formatDate(post.data.date)})</span>
          </span>
        </li>
      ))}
    </ol>
  )}
</Base>
