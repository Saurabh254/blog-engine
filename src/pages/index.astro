---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---
<Base title="my blog">
  <section>
    <h1 class="mb-6 text-sm font-medium uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
      Posts
    </h1>

    {posts.length === 0 ? (
      <p class="text-sm text-zinc-500 dark:text-zinc-400">No posts yet.</p>
    ) : (
      <ol class="space-y-3">
        {posts.map((post, index) => (
          <li class="flex gap-2.5 text-[15px] leading-snug">
            <span class="w-6 shrink-0 text-right tabular-nums text-zinc-400 dark:text-zinc-500">
              {index + 1}.
            </span>
            <span>
              <a
                href={`/${post.id}`}
                class="font-medium text-zinc-900 hover:underline dark:text-zinc-100"
              >
                {post.data.title}
              </a>
              <span class="text-zinc-500 dark:text-zinc-400">
                {' '}({formatDate(post.data.date)})
              </span>
            </span>
          </li>
        ))}
      </ol>
    )}
  </section>
</Base>
